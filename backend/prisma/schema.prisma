generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Run {
  id                   String       @id
  idempotencyKey       String       @unique
  state                String
  target               String
  label                String?
  passportStatus       String?
  gates                Json?
  evidence             Json?
  record               Json?
  canonicalEvidenceJcs String?
  evidenceHash         String?
  manifestHash         String?
  inputHash            String?
  normalizedResultHash String?
  sourceRevision       String?
  buildCommit          String?
  previousRunId        String?
  provider             String?
  signatureState       String?
  evidenceTransaction  String?
  evidenceBlock        String?
  error                String?
  capacityLeaseExpiresAt DateTime?
  publicationTransaction String?
  publicationEvidenceHash String?
  publicationStartedAt DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  invocations          Invocation[]
  payments             Payment[]
}

model Invocation {
  id             String  @id @default(cuid())
  runId          String
  kind           String
  sequence       Int
  input          Json
  output         Json?
  expected       Json?
  comparisons    Json
  classification String?
  latencyMs      Int
  run            Run     @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, kind, sequence])
}

model Payment {
  id                    String   @id
  runId                 String
  kind                  String
  payer                 String?
  recipient             String?
  amount                String
  amountDisplay         String   @default("0")
  assetDecimals         Int      @default(6)
  asset                 String
  network               String
  route                 String
  settlementTransaction String?  @unique
  status                String
  createdAt             DateTime @default(now())
  run                   Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, kind])
}

model Provider {
  address            String   @id
  manifestHash       String
  signature          String?
  verificationResult String
  updatedAt          DateTime @updatedAt
}

model Fixture {
  variant            String @id
  endpoint           String
  sourceUrl          String
  declarationAddress String
}

model CampaignLog {
  id         String   @id @default(cuid())
  category   String
  occurredAt DateTime
  publicUrl  String?
  evidence   Json
  consented  Boolean
}

model ChainCursor {
  id        String   @id
  block     String
  updatedAt DateTime @updatedAt
}
