# LaunchProof local application identity
NODE_ENV=development
PUBLIC_API_BASE_URL=http://localhost:4000
PUBLIC_WEB_BASE_URL=http://localhost:3000
PUBLIC_ALLOWED_ORIGINS=http://localhost:3000
# Set this to the output of: git rev-parse HEAD
BUILD_COMMIT_SHA=
# Public release images must use BUILD_COMMIT_SHA as the tag and record the
# registry-provided immutable digest (sha256: followed by 64 hex characters).
RELEASE_IMAGE_TAG=
RELEASE_IMAGE_DIGEST=
SOURCE_REPOSITORY=https://github.com/Kevincruz2005/LaunchProof
OKX_AI_LISTING_URL=
DEMO_VIDEO_URL=
REFERENCE_PAYMENT_ID=

# X Layer TESTNET only. These are public network identifiers, not secrets.
XLAYER_TESTNET=true
ALLOW_XLAYER_MAINNET=false
XLAYER_CHAIN_ID=1952
XLAYER_NETWORK=eip155:1952
XLAYER_USDT0_ADDRESS=0x9e29b3aada05bf2d2c827af80bd28dc0b9b4fb0c
XLAYER_EXPLORER_URL=https://www.okx.com/web3/explorer/xlayer-test
XLAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
XLAYER_FALLBACK_RPC_URL=https://xlayertestrpc.okx.com/terigon

# Fill these from a fresh deployment. Never reuse the credentials previously
# published in chat or committed to a script.
REGISTRY_ADDRESS=
REGISTRY_DEPLOYMENT_BLOCK=0
REGISTRY_RUNTIME_CODE_HASH=
REGISTRY_WRITER_ADDRESS=
REGISTRY_WRITER_PRIVATE_KEY=
TARGET_PAYER_ADDRESS=
TARGET_PAYER_PRIVATE_KEY=
PAYOUT_ADDRESS=
DEPLOYER_ADDRESS=
# DEPLOYER_PRIVATE_KEY is deliberately absent. Supply it only to forge at deploy time.
# PAYOUT_PRIVATE_KEY is deliberately absent. Keep it in offline/segregated custody.

# Official OKX x402 facilitator. Rotate any credential that has been shared.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_BASE_URL=https://web3.okx.com
X402_ENABLED=false

# PostgreSQL cache/index
POSTGRES_DB=launchproof
POSTGRES_USER=launchproof
POSTGRES_PASSWORD=
DATABASE_URL=
# Must be a direct or session-mode PostgreSQL connection. Transaction-pooler
# URLs cannot safely hold the session advisory lock.
LEADERSHIP_DATABASE_URL=
LEADERSHIP_DATABASE_MODE=session

# Payment and service safety limits
TARGET_PAYMENT_MAX_USDT0=0.10
TARGET_PAYMENT_DAILY_LIMIT_USDT0=1.00
TARGET_ALLOWLIST=
MAX_CONCURRENT_RUNS=3
FREE_RATE_LIMIT_PER_MINUTE=60
PAID_RATE_LIMIT_PER_HOUR=6
GLOBAL_RUN_LIMIT_PER_DAY=100
PASSPORT_GATE_WARN_AGE_HOURS=24
PASSPORT_GATE_MAX_AGE_HOURS=168

# Exact fixture identities. Startup scripts fill the public URLs and addresses.
FIXTURE_HEALTHY_URL=
FIXTURE_INVALID_OUTPUT_URL=
FIXTURE_SCHEMA_DRIFT_URL=
FIXTURE_TIMEOUT_URL=
FIXTURE_HEALTHY_PROVIDER_ADDRESS=
FIXTURE_INVALID_OUTPUT_PROVIDER_ADDRESS=
FIXTURE_SCHEMA_DRIFT_PROVIDER_ADDRESS=
FIXTURE_TIMEOUT_PROVIDER_ADDRESS=
FIXTURE_HEALTHY_PROVIDER_PRIVATE_KEY=
FIXTURE_INVALID_OUTPUT_PROVIDER_PRIVATE_KEY=
FIXTURE_SCHEMA_DRIFT_PROVIDER_PRIVATE_KEY=
FIXTURE_TIMEOUT_PROVIDER_PRIVATE_KEY=
# Required as "external-secret" in production fixture processes. Development
# keys generated by repository helpers are intentionally refused publicly.
FIXTURE_PROVIDER_KEY_SOURCE=
FIXTURE_X402_ENABLED=false
FIXTURE_PAYMENT_RECIPIENT=
FIXTURE_PAYMENT_AMOUNT_ATOMIC=10000
# Optional, used only by scripts/start-fixtures-ngrok.sh.
NGROK_AUTHTOKEN=

# Development escape hatches. Keep both false for public/tunnel rehearsals.
ALLOW_LOCAL_UNPAID_RUNS=false
ALLOW_PRIVATE_TARGETS=false

# Browser-visible values. Never put a secret behind NEXT_PUBLIC_.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_XLAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_PAYOUT_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=1952
NEXT_PUBLIC_WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SOURCE_REPOSITORY=https://github.com/Kevincruz2005/LaunchProof
NEXT_PUBLIC_REGISTRY_DEPLOYMENT_BLOCK=0
