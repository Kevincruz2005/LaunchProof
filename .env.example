# Public service identity
NODE_ENV=development
PUBLIC_API_BASE_URL=http://localhost:4000
PUBLIC_WEB_BASE_URL=http://localhost:3000
BUILD_COMMIT_SHA=development
SOURCE_REPOSITORY=https://github.com/your-org/launchproof
OKX_AI_LISTING_URL=
DEMO_VIDEO_URL=
REFERENCE_PAYMENT_ID=

# X Layer mainnet (chain ID 196)
XLAYER_RPC_URL=
XLAYER_FALLBACK_RPC_URL=
REGISTRY_ADDRESS=
REGISTRY_DEPLOYMENT_BLOCK=0
REGISTRY_WRITER_PRIVATE_KEY=
TARGET_PAYER_PRIVATE_KEY=
PAYOUT_ADDRESS=

# Official OKX x402 facilitator
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_BASE_URL=
X402_ENABLED=false

# Cache/index
DATABASE_URL=postgresql://launchproof:launchproof@localhost:5432/launchproof

# Safety limits
TARGET_PAYMENT_MAX_USDT0=0.10
TARGET_PAYMENT_DAILY_LIMIT_USDT0=1.00
TARGET_ALLOWLIST=
MAX_CONCURRENT_RUNS=3
FREE_RATE_LIMIT_PER_MINUTE=60
PAID_RATE_LIMIT_PER_HOUR=6
GLOBAL_RUN_LIMIT_PER_DAY=100
FIXTURE_BASE_DOMAIN=
FIXTURE_HEALTHY_PROVIDER_ADDRESS=
FIXTURE_INVALID_OUTPUT_PROVIDER_ADDRESS=
FIXTURE_SCHEMA_DRIFT_PROVIDER_ADDRESS=
FIXTURE_TIMEOUT_PROVIDER_ADDRESS=

# Per-fixture deployment values (each fixture receives its own environment)
PUBLIC_BASE_URL=
SOURCE_REVISION=
FIXTURE_PROVIDER_PRIVATE_KEY=
PAYMENT_RECIPIENT=
PAYMENT_AMOUNT_ATOMIC=10000

# Development only. Never enable on a public deployment.
ALLOW_LOCAL_UNPAID_RUNS=false
ALLOW_PRIVATE_TARGETS=false

# Frontend public values (never put a secret behind NEXT_PUBLIC_)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_XLAYER_RPC_URL=
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=196
NEXT_PUBLIC_WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SOURCE_REPOSITORY=https://github.com/your-org/launchproof
NEXT_PUBLIC_REGISTRY_DEPLOYMENT_BLOCK=
