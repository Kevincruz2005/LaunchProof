{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LaunchProof Launch Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "service_name", "mcp_endpoint", "tool", "mode", "sample_input", "assertions", "max_latency_ms", "delivery_type", "payment_mode", "safe_use", "source_revision", "challenge_profile", "provider_address"],
  "properties": {
    "contract_version": { "const": "1.0" },
    "service_name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "mcp_endpoint": {
      "$ref": "#/$defs/public_endpoint"
    },
    "tool": { "type": "string", "minLength": 1, "maxLength": 80 },
    "mode": { "const": "sample_only" },
    "sample_input": {
      "type": "object",
      "maxProperties": 20,
      "propertyNames": { "type": "string", "maxLength": 80 },
      "additionalProperties": { "$ref": "#/$defs/primitive" }
    },
    "assertions": {
      "type": "array", "minItems": 1, "maxItems": 20,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["path", "rule", "value"],
        "properties": {
          "path": { "type": "string", "pattern": "^\\$\\.[A-Za-z0-9_]+$", "maxLength": 100 },
          "rule": { "enum": ["equals", "gte", "lte"] },
          "value": { "$ref": "#/$defs/primitive" }
        },
        "allOf": [
          {
            "if": { "properties": { "rule": { "enum": ["gte", "lte"] } }, "required": ["rule"] },
            "then": { "properties": { "value": { "type": "number" } } }
          }
        ]
      }
    },
    "max_latency_ms": { "type": "integer", "minimum": 100, "maximum": 8000 },
    "delivery_type": { "const": "synchronous_json" },
    "payment_mode": { "enum": ["none", "x402_optional"] },
    "payment": {
      "type": "object", "additionalProperties": false,
      "required": ["network", "asset", "amount", "recipient", "resource_url"],
      "properties": {
        "network": {
          "type": "string",
          "pattern": "^eip155:[1-9][0-9]*$",
          "examples": ["eip155:1952"],
          "$comment": "The service validates this against XLAYER_NETWORK at runtime."
        },
        "asset": {
          "type": "string",
          "pattern": "^0x(?!0{40}$)[0-9a-fA-F]{40}$",
          "examples": ["0x9e29b3aada05bf2d2c827af80bd28dc0b9b4fb0c"],
          "$comment": "The service validates this against XLAYER_USDT0_ADDRESS at runtime."
        },
        "amount": { "type": "string", "pattern": "^[1-9][0-9]*$" },
        "recipient": { "type": "string", "pattern": "^0x(?!0{40}$)[0-9a-fA-F]{40}$" },
        "resource_url": { "$ref": "#/$defs/public_endpoint" }
      }
    },
    "safe_use": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 },
      "allOf": [
        { "contains": { "type": "string", "pattern": "read[- ]only" } },
        { "contains": { "type": "string", "pattern": "(synthetic|sample)" } },
        { "contains": { "type": "string", "pattern": "no (credentials?|account|cookies?)" } },
        { "contains": { "type": "string", "pattern": "no (external )?(tool )?(side effects?|writes?)" } }
      ],
      "$comment": "Runtime additionally rejects contradictory positive write/credential/side-effect claims."
    },
    "source_revision": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "challenge_profile": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "tool", "input_field", "output_fields", "challenge_runs", "max_latency_ms_per_run", "safe_mode"],
      "properties": {
        "name": { "const": "structured-extraction-v1" },
        "tool": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "$comment": "The runtime additionally requires this value to equal the top-level tool; standard JSON Schema cannot express cross-property equality."
        },
        "input_field": { "type": "string", "minLength": 1, "maxLength": 80 },
        "output_fields": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "enum": ["document_id", "currency", "total", "due_date"] }
        },
        "challenge_runs": { "const": 3 },
        "max_latency_ms_per_run": { "type": "integer", "minimum": 100, "maximum": 8000 },
        "safe_mode": { "const": "synthetic_read_only" }
      }
    },
    "provider_address": { "type": "string", "pattern": "^0x(?!0{40}$)[0-9a-fA-F]{40}$" },
    "declaration_signature": { "type": "string", "pattern": "^0x[0-9a-fA-F]{130}$" },
    "fixture": { "type": "boolean" }
  },
  "$defs": {
    "public_endpoint": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048,
      "pattern": "^https://[^/?#@\\s]+(?:/[^?#\\s]*)?$",
      "$comment": "Public endpoints are HTTPS URLs without embedded credentials, query strings, or fragments. Runtime network policy additionally validates DNS and ports."
    },
    "primitive": {
      "oneOf": [
        { "type": "string", "maxLength": 5000 },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "payment_mode": { "const": "x402_optional" } }, "required": ["payment_mode"] },
      "then": { "properties": { "payment": {} }, "required": ["payment"] },
      "else": { "properties": { "payment": false } }
    },
    {
      "if": { "properties": { "fixture": { "const": true } }, "required": ["fixture"] },
      "then": { "properties": { "declaration_signature": {} }, "required": ["declaration_signature"] }
    }
  ]
}
