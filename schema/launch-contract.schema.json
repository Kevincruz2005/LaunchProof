{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://launchproof.example/schema/launch-contract.schema.json",
  "title": "LaunchProof Launch Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "service_name", "mcp_endpoint", "tool", "mode", "sample_input", "assertions", "max_latency_ms", "delivery_type", "payment_mode", "safe_use", "source_revision", "challenge_profile", "provider_address"],
  "properties": {
    "contract_version": { "const": "1.0" },
    "service_name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "mcp_endpoint": { "type": "string", "format": "uri", "pattern": "^https://" },
    "tool": { "type": "string", "minLength": 1, "maxLength": 80 },
    "mode": { "const": "sample_only" },
    "sample_input": { "type": "object", "maxProperties": 20 },
    "assertions": {
      "type": "array", "minItems": 1, "maxItems": 20,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["path", "rule", "value"],
        "properties": {
          "path": { "type": "string", "pattern": "^\\$\\.[A-Za-z0-9_]+$", "maxLength": 100 },
          "rule": { "enum": ["equals", "gte", "lte", "regex"] },
          "value": {},
          "flags": { "type": "string", "pattern": "^[imsu]*$", "maxLength": 4 }
        }
      }
    },
    "max_latency_ms": { "type": "integer", "minimum": 100, "maximum": 8000 },
    "delivery_type": { "const": "synchronous_json" },
    "payment_mode": { "enum": ["none", "x402_optional"] },
    "payment": {
      "type": "object", "additionalProperties": false,
      "required": ["network", "asset", "amount", "recipient", "resource_url"],
      "properties": {
        "network": { "const": "eip155:196" },
        "asset": { "const": "0x779ded0c9e1022225f8e0630b35a9b54be713736" },
        "amount": { "type": "string", "pattern": "^[0-9]+$" },
        "recipient": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
        "resource_url": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "safe_use": { "type": "array", "minItems": 1, "maxItems": 10, "items": { "type": "string", "maxLength": 120 } },
    "source_revision": { "type": "string", "minLength": 1, "maxLength": 100 },
    "challenge_profile": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "tool", "input_field", "output_fields", "challenge_runs", "max_latency_ms_per_run", "safe_mode"],
      "properties": {
        "name": { "const": "structured-extraction-v1" },
        "tool": { "type": "string", "minLength": 1, "maxLength": 80 },
        "input_field": { "type": "string", "minLength": 1, "maxLength": 80 },
        "output_fields": { "type": "array", "minItems": 1, "maxItems": 10, "uniqueItems": true, "items": { "type": "string", "maxLength": 80 } },
        "challenge_runs": { "const": 3 },
        "max_latency_ms_per_run": { "type": "integer", "minimum": 100, "maximum": 8000 },
        "safe_mode": { "const": "synthetic_read_only" }
      }
    },
    "provider_address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "declaration_signature": { "type": "string", "pattern": "^0x[0-9a-fA-F]{130}$" },
    "fixture": { "type": "boolean" }
  },
  "allOf": [
    { "if": { "properties": { "payment_mode": { "const": "x402_optional" } } }, "then": { "required": ["payment"] }, "else": { "not": { "required": ["payment"] } } }
  ]
}
