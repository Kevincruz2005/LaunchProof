{
  "name": "launchproof",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.18.1 <25",
    "pnpm": "10.13.1"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --filter @launchproof/backend --filter @launchproof/frontend dev",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm --filter @launchproof/fixture-runtime build && pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "contract:build": "node scripts/compile-contract.mjs",
    "fixtures:build": "pnpm --filter @launchproof/fixture-runtime build && pnpm --filter './fixtures/invoice-normalizer-*' build",
    "fixtures:local": "bash scripts/start-fixtures-local.sh",
    "keys:testnet": "node scripts/generate-testnet-keys.mjs",
    "registry:deploy-testnet": "node scripts/deploy-testnet-registry.mjs",
    "registry:record-testnet": "node scripts/record-testnet-deployment.mjs",
    "testnet:validate": "node scripts/validate-demo-env.mjs",
    "check": "pnpm contract:build && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "localtunnel": "2.0.2",
    "solc": "0.8.24"
  }
}
